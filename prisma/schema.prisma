generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- User & Auth ----

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  
  // Gamification
  xp            Int       @default(0)
  streakDays    Int       @default(0)
  lastActiveAt  DateTime?
  
  // Subscription & billing
  plan              String    @default("free") // "free" | "pro" | "lifetime"
  stripeCustomerId  String?   @unique
  stripeSubscriptionId String?
  planExpiresAt     DateTime?
  freeCredits       Int       @default(3)  // Lesson credits for free tier
  creditsUsed       Int       @default(0)  // Total credits consumed
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  accounts        Account[]
  sessions        Session[]
  lessonProgress  LessonProgress[]
  courseProgress   CourseProgress[]
  bookmarks       Bookmark[]
  notes           Note[]
  chatMessages    ChatMessage[]
  
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---- Lessons (Flash Lessons) ----

model Lesson {
  id            String   @id @default(cuid())
  topic         String
  slug          String   @unique
  type          LessonType @default(FLASH)
  
  // AI-generated content
  plan          Json     // Lesson plan / outline
  content       Json     // Structured lesson sections with text + image descriptions
  coverImageUrl String?
  
  // Metadata
  estimatedMinutes Int    @default(5)
  difficulty       String @default("intermediate")
  tags             String[] 
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  quiz           Quiz?
  progress       LessonProgress[]
  bookmarks      Bookmark[]
  notes          Note[]
  chatMessages   ChatMessage[]
  
  // If part of a course
  moduleId       String?
  moduleOrder    Int?
  module         Module? @relation(fields: [moduleId], references: [id])
  
  @@index([topic])
  @@index([slug])
  @@map("lessons")
}

enum LessonType {
  FLASH
  COURSE_LESSON
}

// ---- Courses (Deep Dive) ----

model Course {
  id               String   @id @default(cuid())
  topic            String
  slug             String   @unique
  
  // AI-generated
  syllabus         Json     // Full course structure
  description      String
  coverImageUrl    String?
  
  // Metadata
  estimatedMinutes Int      @default(60)
  moduleCount      Int      @default(0)
  lessonCount      Int      @default(0)
  difficulty       String   @default("intermediate")
  tags             String[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  modules          Module[]
  progress         CourseProgress[]
  
  @@index([topic])
  @@index([slug])
  @@map("courses")
}

model Module {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int
  
  createdAt   DateTime @default(now())
  
  // Relations
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  quiz        Quiz?
  
  @@index([courseId])
  @@map("modules")
}

// ---- Quizzes ----

model Quiz {
  id         String   @id @default(cuid())
  
  // Can belong to a lesson or a module
  lessonId   String?  @unique
  moduleId   String?  @unique
  
  questions  Json     // Array of {question, options, correctIndex, explanation}
  
  createdAt  DateTime @default(now())
  
  // Relations
  lesson     Lesson?  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  module     Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  
  @@map("quizzes")
}

// ---- User Progress ----

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  
  completed   Boolean  @default(false)
  quizScore   Int?     // Percentage 0-100
  quizAnswers Json?    // User's answers for review
  xpEarned    Int      @default(0)
  
  startedAt   DateTime @default(now())
  completedAt DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model CourseProgress {
  id            String   @id @default(cuid())
  userId        String
  courseId       String
  
  currentModule Int      @default(0)
  currentLesson Int      @default(0)
  completionPct Float    @default(0)
  completed     Boolean  @default(false)
  xpEarned      Int      @default(0)
  
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@map("course_progress")
}

// ---- Bookmarks & Notes ----

model Bookmark {
  id            String   @id @default(cuid())
  userId        String
  lessonId      String
  highlightText String?
  sectionIndex  Int?     // Which section of the lesson
  
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId, sectionIndex])
  @@map("bookmarks")
}

model Note {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  content      String
  sectionIndex Int?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@map("notes")
}

// ---- AI Tutor Chat ----

model ChatMessage {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String
  role       String   // "user" | "assistant"
  content    String
  
  createdAt  DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@index([userId, lessonId])
  @@map("chat_messages")
}
