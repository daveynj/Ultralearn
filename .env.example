# UltraLearn Environment Variables
# Copy this to .env.local and fill in your values

# ---- AI Providers ----
OPENROUTER_API_KEY=your_openrouter_api_key_here
GOOGLE_AI_API_KEY=your_google_api_key_here

# ---- Image Generation ----
STABILITY_AI_API_KEY=your_stability_ai_api_key_here
RUNWARE_API_KEY=your_runware_api_key_here

# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/ultralearn

# ---- Auth (Auth.js) ----
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---- App Config ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_PRO_YEARLY_PRICE_ID=price_your_yearly_price_id
STRIPE_LIFETIME_PRICE_ID=price_your_lifetime_price_id
